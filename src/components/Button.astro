---
interface Props {
  href: string;
  variant?: "primary" | "secondary" | "ghost";
  size?: "md" | "lg";
  external?: boolean;
  class?: string;
}
const { href, variant = "primary", size = "md", external = false, class: cls = "" } = Astro.props;
const rel = external ? "noopener noreferrer" : undefined;
const target = external ? "_blank" : undefined;
---

<a href={href} class:list={["btn", variant, size, cls]} rel={rel} target={target}>
  <slot />
  {
    variant === "primary" && (
      <svg class="arr" width="14" height="14" viewBox="0 0 14 14" aria-hidden="true">
        <path d="M3 7h7M7 4l3 3-3 3" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    )
  }
</a>

<style>
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-weight: var(--fw-medium);
    border-radius: var(--r-full);
    border: 1px solid transparent;
    transition: all var(--t-fast) var(--ease);
    white-space: nowrap;
  }
  .md { padding: 0.55rem 1.1rem; font-size: var(--ft-sm); }
  .lg { padding: 0.75rem 1.4rem; font-size: var(--ft-md); }
  .primary { background: var(--color-primary); color: var(--color-on-primary); }
  .primary:hover { background: var(--color-primary-hover); transform: translateY(-1px); box-shadow: var(--shadow-md); }
  .secondary { background: var(--color-surface); color: var(--color-text); border-color: var(--color-border-strong); }
  .secondary:hover { border-color: var(--color-text-tertiary); transform: translateY(-1px); }
  .ghost { color: var(--color-text-secondary); }
  .ghost:hover { color: var(--color-primary); }
  .arr { transition: transform var(--t-fast) var(--ease); }
  .primary:hover .arr { transform: translateX(2px); }
</style>
