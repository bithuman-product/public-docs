---
// WYSIWYG "Try it" playground: pick an agent (custom dropdown with avatar icons)
// + model on the left (the embed code updates live), hit Launch, and the real
// agent runs in the preview on the right.
import data from "../data/showcase-agents.json";

interface Props {
  /** Compact = preview-only (poster + Launch), no code editor. Used in the hero to protect LCP. */
  compact?: boolean;
}
const { compact = false } = Astro.props;

const agents = [...data.expression, ...data.essence];
const first = agents[0];
---

<div class:list={["pg", { compact }]} data-pg data-pg-first-code={first.code} data-pg-first-model={first.group}>
  {!compact && (
  <div class="pg-left">
    <div class="pg-controls">
      <div class="pg-field">
        <span>Agent</span>
        <div class="pg-combo" data-pg-combo>
          <button type="button" class="pg-combo-btn" data-pg-btn aria-haspopup="listbox" aria-expanded="false"
            data-code={first.code} data-image={first.image} data-model={first.group}>
            <img class="pg-av" src={first.image} alt="" loading="lazy" decoding="async" />
            <span class="pg-combo-name">{first.name}</span>
            <svg class="pg-chev" width="12" height="12" viewBox="0 0 12 12" aria-hidden="true"><path d="M2.5 4.5 6 8l3.5-3.5" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          </button>
          <div class="pg-combo-list" role="listbox" hidden>
            <div class="pg-grp">Expression</div>
            {data.expression.map((a) => (
              <button type="button" class="pg-opt" role="option" data-code={a.code} data-image={a.image} data-name={a.name} data-model="expression">
                <img class="pg-av" src={a.image} alt="" loading="lazy" decoding="async" /><span>{a.name}</span>
              </button>
            ))}
            <div class="pg-grp">Essence</div>
            {data.essence.map((a) => (
              <button type="button" class="pg-opt" role="option" data-code={a.code} data-image={a.image} data-name={a.name} data-model="essence">
                <img class="pg-av" src={a.image} alt="" loading="lazy" decoding="async" /><span>{a.name}</span>
              </button>
            ))}
          </div>
        </div>
      </div>
      <div class="pg-field">
        <span>Model</span>
        <div class="pg-seg" data-pg-model>
          <button class="active" data-val="expression">Expression</button>
          <button data-val="essence">Essence</button>
        </div>
      </div>
    </div>

    <div class="pg-code">
      <div class="pg-code-bar">
        <span class="pg-dots"><i></i><i></i><i></i></span>
        <span class="pg-file">embed.html</span>
        <button class="pg-copy" data-pg-copy>Copy</button>
      </div>
      <pre><code data-pg-code></code></pre>
    </div>

    <button class="pg-run" data-pg-run><span class="dot"></span> Launch agent</button>
  </div>
  )}

  <div class="pg-right">
    <div class="pg-preview" data-pg-preview>
      {compact ? (
        <img data-pg-poster src={first.image} alt={first.name} fetchpriority="high" decoding="async" width="960" height="600" />
      ) : (
        <img data-pg-poster src={first.image} alt={first.name} loading="lazy" decoding="async" />
      )}
      <div class="pg-hint"><span>▶</span> Press <strong>Launch</strong> to talk to a live agent</div>
      {compact && (
        <button class="pg-run pg-run-compact" data-pg-run><span class="dot"></span> Launch agent</button>
      )}
      <button class="pg-close" data-pg-close aria-label="Close">
        <svg width="16" height="16" viewBox="0 0 16 16" aria-hidden="true"><path d="M4 4l8 8M12 4l-8 8" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
      </button>
    </div>
  </div>
</div>

<script>
  document.querySelectorAll("[data-pg]").forEach((root) => {
    const r = root as HTMLElement;
    const combo = root.querySelector("[data-pg-combo]") as HTMLElement | null;
    const btn = root.querySelector("[data-pg-btn]") as HTMLElement | null;
    const list = root.querySelector(".pg-combo-list") as HTMLElement | null;
    const seg = root.querySelector("[data-pg-model]") as HTMLElement | null;
    const codeEl = root.querySelector("[data-pg-code]") as HTMLElement | null;
    const poster = root.querySelector("[data-pg-poster]") as HTMLImageElement;
    const preview = root.querySelector("[data-pg-preview]")!;

    // In compact (hero) mode there is no picker/code editor; the agent comes from
    // the root data attributes and only the Launch/preview path is active.
    const compact = r.classList.contains("compact");
    let model = btn?.dataset.model || r.dataset.pgFirstModel || "expression";
    // current selected agent code (kept on the picker button when present)
    const currentCode = () => btn?.dataset.code || r.dataset.pgFirstCode!;

    const snippet = (code: string, m: string) =>
      `<iframe\n  src="https://bithuman.ai/embed/${code}?model=${m}"\n  allow="microphone *; camera *; autoplay *"\n  style="width:100%;height:100%;border:0">\n</iframe>`;

    const setModelUI = () =>
      seg?.querySelectorAll("button").forEach((b) => b.classList.toggle("active", (b as HTMLElement).dataset.val === model));

    const sync = () => {
      if (codeEl) codeEl.textContent = snippet(currentCode(), model);
      if (btn?.dataset.image) poster.src = btn.dataset.image;
      const f = preview.querySelector("iframe");
      if (f) { f.remove(); preview.classList.remove("live"); }
    };

    if (!compact && btn && list && combo) {
      // dropdown open/close
      const open = (o: boolean) => { list.hidden = !o; btn.setAttribute("aria-expanded", o ? "true" : "false"); };
      btn.addEventListener("click", () => open(list.hidden));
      document.addEventListener("click", (e) => { if (!combo.contains(e.target as Node)) open(false); });
      root.querySelectorAll(".pg-opt").forEach((opt) =>
        opt.addEventListener("click", () => {
          const o = opt as HTMLElement;
          btn.dataset.code = o.dataset.code; btn.dataset.image = o.dataset.image;
          (btn.querySelector(".pg-av") as HTMLImageElement).src = o.dataset.image!;
          (btn.querySelector(".pg-combo-name") as HTMLElement).textContent = o.dataset.name!;
          model = o.dataset.model!; setModelUI();
          list.querySelectorAll(".pg-opt").forEach((x) => x.classList.toggle("sel", x === opt));
          open(false); sync();
        })
      );

      seg?.querySelectorAll("button").forEach((b) =>
        b.addEventListener("click", () => { model = (b as HTMLElement).dataset.val!; setModelUI(); sync(); })
      );
    }

    root.querySelector("[data-pg-run]")?.addEventListener("click", () => {
      const f = document.createElement("iframe");
      f.src = `https://bithuman.ai/embed/${currentCode()}?model=${model}`;
      f.allow = "microphone *; camera *; autoplay *; clipboard-write";
      f.title = "bitHuman live agent"; f.className = "pg-frame";
      preview.querySelector(".pg-frame")?.remove();
      preview.appendChild(f); preview.classList.add("live");
    });
    root.querySelector("[data-pg-close]")?.addEventListener("click", () => {
      preview.querySelector(".pg-frame")?.remove(); preview.classList.remove("live");
    });
    root.querySelector("[data-pg-copy]")?.addEventListener("click", (e) => {
      const b = e.currentTarget as HTMLElement;
      navigator.clipboard.writeText(codeEl?.textContent ?? "").then(() => {
        b.textContent = "Copied"; setTimeout(() => (b.textContent = "Copy"), 1400);
      }).catch(() => {});
    });

    sync();
  });
</script>

<style>
  .pg { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-5); align-items: start; }
  .pg-left { display: flex; flex-direction: column; gap: var(--space-4); }
  .pg-controls { display: flex; gap: var(--space-5); flex-wrap: wrap; }
  .pg-field { display: flex; flex-direction: column; gap: 0.4rem; }
  .pg-field > span { font-size: var(--ft-xs); text-transform: uppercase; letter-spacing: 0.06em; color: var(--color-text-tertiary); }
  .pg-av { width: 22px; height: 22px; border-radius: 50%; object-fit: cover; flex: none; }

  /* custom agent dropdown */
  .pg-combo { position: relative; }
  .pg-combo-btn { display: inline-flex; align-items: center; gap: 0.5rem; min-width: 220px; padding: 0.4rem 0.6rem; border-radius: var(--r-md); border: 1px solid var(--color-border); background: var(--color-surface); color: var(--color-text); font: inherit; font-size: var(--ft-sm); cursor: pointer; }
  .pg-combo-btn:hover { border-color: var(--color-border-strong); }
  .pg-combo-name { flex: 1; text-align: left; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .pg-chev { color: var(--color-text-tertiary); }
  .pg-combo-list { position: absolute; top: calc(100% + 6px); left: 0; z-index: 20; width: 280px; max-height: 320px; overflow-y: auto; padding: 0.35rem; background: var(--color-elevated); border: 1px solid var(--color-border); border-radius: var(--r-lg); box-shadow: var(--shadow-lg); }
  .pg-grp { font-size: var(--ft-xs); text-transform: uppercase; letter-spacing: 0.06em; color: var(--color-text-tertiary); padding: 0.5rem 0.6rem 0.25rem; }
  .pg-opt { display: flex; align-items: center; gap: 0.6rem; width: 100%; padding: 0.45rem 0.6rem; border: 0; border-radius: var(--r-md); background: none; color: var(--color-text); font: inherit; font-size: var(--ft-sm); text-align: left; cursor: pointer; }
  .pg-opt:hover { background: var(--color-surface-2); }
  .pg-opt.sel { background: var(--color-primary-soft); color: var(--color-primary); }
  .pg-opt .pg-av { width: 28px; height: 28px; }

  .pg-seg { display: inline-flex; border: 1px solid var(--color-border); border-radius: var(--r-md); overflow: hidden; }
  .pg-seg button { padding: 0.5rem 0.9rem; border: 0; background: var(--color-surface); color: var(--color-text-secondary); font-size: var(--ft-sm); font-weight: var(--fw-medium); }
  .pg-seg button.active { background: var(--color-primary); color: var(--color-on-primary); }

  .pg-code { flex: 1; border: 1px solid var(--color-border); border-radius: var(--r-lg); overflow: hidden; background: var(--color-code-bg); display: flex; flex-direction: column; }
  .pg-code-bar { display: flex; align-items: center; gap: 0.6rem; padding: 0.4rem 0.6rem; background: var(--color-surface-2); border-bottom: 1px solid var(--color-border); }
  .pg-dots { display: inline-flex; gap: 4px; }
  .pg-dots i { width: 9px; height: 9px; border-radius: 50%; background: var(--color-border-strong); }
  .pg-file { font-size: var(--ft-xs); color: var(--color-text-tertiary); font-family: var(--font-mono); }
  .pg-copy { margin-left: auto; border: 0; background: none; color: var(--color-text-tertiary); font-size: var(--ft-xs); cursor: pointer; }
  .pg-copy:hover { color: var(--color-text); }
  .pg-code pre { margin: 0; padding: var(--space-4); overflow-x: auto; flex: 1; }
  .pg-code code { font-family: var(--font-mono); font-size: 0.8rem; line-height: 1.6; color: var(--color-text); white-space: pre; }

  .pg-run { display: inline-flex; align-items: center; justify-content: center; gap: 0.5rem; padding: 0.75rem 1.2rem; border: 0; border-radius: var(--r-full); background: var(--color-primary); color: var(--color-on-primary); font-weight: var(--fw-medium); font-size: var(--ft-md); transition: all var(--t-fast) var(--ease); }
  .pg-run:hover { background: var(--color-primary-hover); transform: translateY(-1px); box-shadow: var(--shadow-md); }
  .pg-run .dot { width: 8px; height: 8px; border-radius: 50%; background: #fff; }

  .pg-right { display: flex; }
  .pg-preview { position: relative; width: 100%; height: clamp(420px, 56vh, 520px); border-radius: var(--r-2xl); overflow: hidden; border: 1px solid var(--color-border); background: var(--color-surface-3); }
  .pg-preview img { width: 100%; height: 100%; object-fit: cover; }
  .pg-preview :global(.pg-frame) { position: absolute; inset: 0; width: 100%; height: 100%; border: 0; }
  .pg-hint { position: absolute; inset-inline: 0; bottom: 0; padding: var(--space-5); background: linear-gradient(180deg, transparent, rgba(0,0,0,0.7)); color: #fff; font-size: var(--ft-sm); display: flex; align-items: center; gap: 0.5rem; }
  .pg-hint span { display: inline-grid; place-items: center; width: 22px; height: 22px; border-radius: 50%; background: rgba(255,255,255,0.9); color: #111; font-size: 0.7rem; }
  .pg-close { position: absolute; top: var(--space-3); right: var(--space-3); display: none; align-items: center; justify-content: center; width: 32px; height: 32px; padding: 0; border: 0; border-radius: 50%; background: rgba(0,0,0,0.6); color: #fff; z-index: 2; line-height: 0; }
  .pg-close:hover { background: rgba(0,0,0,0.85); }
  .pg-preview.live .pg-hint { display: none; }
  .pg-preview.live .pg-close { display: inline-flex; }

  /* ---- compact (hero) variant: preview-only, single column ---- */
  .pg.compact { grid-template-columns: 1fr; gap: 0; }
  /* Width-driven sizing: a fixed height + aspect-ratio gives the preview an
     intrinsic (transferred) width that can inflate the hero grid track and
     push the card — and its Launch pill — past the viewport edge (seen at
     1440px). Let the column width drive the height via the aspect ratio. */
  .pg.compact .pg-preview { height: auto; aspect-ratio: 16/10; }
  .pg-run-compact { position: absolute; bottom: var(--space-4); right: var(--space-4); z-index: 3; padding: 0.6rem 1rem; font-size: var(--ft-sm); box-shadow: var(--shadow-md); }
  .pg-preview.live .pg-run-compact { display: none; }

  @media (max-width: 860px) {
    .pg { grid-template-columns: 1fr; }
    .pg-controls { gap: var(--space-4); }
    .pg-combo-btn, .pg-combo-list { min-width: 0; width: 100%; }
    .pg-code { min-height: 150px; }
    .pg-preview { height: clamp(380px, 82vw, 460px); max-width: 360px; margin-inline: auto; }
  }
</style>
