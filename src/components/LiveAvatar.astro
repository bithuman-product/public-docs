---
// Lazy live-avatar embed. Shows a poster until the visitor clicks "Try it live",
// then swaps in the agent.viewer.bithuman.ai iframe (avoids an autoplay mic prompt
// on page load). `code` is a public gallery agent code.
interface Props {
  code: string;
  name?: string;
  poster?: string;
  class?: string;
}
const { code, name = "Live demo", poster = "/images/example-agent-images.jpg", class: cls = "" } = Astro.props;
const src = `https://agent.viewer.bithuman.ai/api/embed/${code}`;
---

<div class:list={["live", cls]} data-src={src}>
  <div class="live-frame">
    <div class="live-poster" style={`background-image:url(${poster})`}>
      <button class="live-play" type="button" aria-label={`Start ${name}`}>
        <span class="dot"></span>
        <svg width="20" height="20" viewBox="0 0 20 20" aria-hidden="true"><path d="M6 4.5v11l9-5.5-9-5.5Z" fill="currentColor"></path></svg>
        Try it live
      </button>
      <span class="live-tag">{name}</span>
    </div>
  </div>
</div>

<script>
  document.querySelectorAll(".live").forEach((el) => {
    const btn = el.querySelector(".live-play");
    const src = (el as HTMLElement).dataset.src!;
    btn?.addEventListener("click", () => {
      const frame = el.querySelector(".live-frame")!;
      const iframe = document.createElement("iframe");
      iframe.src = src;
      iframe.allow = "microphone; camera; autoplay; clipboard-write";
      iframe.setAttribute("title", "bitHuman live avatar");
      iframe.style.cssText = "width:100%;height:100%;border:0;display:block;";
      frame.innerHTML = "";
      frame.appendChild(iframe);
    });
  });
</script>

<style>
  .live { width: 100%; }
  .live-frame {
    position: relative;
    aspect-ratio: 3 / 4;
    border-radius: var(--r-2xl);
    overflow: hidden;
    border: 1px solid var(--color-border);
    background: var(--color-surface-3);
    box-shadow: var(--shadow-glow);
  }
  .live-poster {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    padding: var(--space-5);
  }
  .live-poster::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(0, 0, 0, 0.05), rgba(0, 0, 0, 0.55));
  }
  .live-play {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.7rem 1.2rem;
    border-radius: var(--r-full);
    border: 0;
    background: rgba(255, 255, 255, 0.95);
    color: #111;
    font-weight: var(--fw-medium);
    box-shadow: var(--shadow-md);
    transition: transform var(--t-fast) var(--ease);
  }
  .live-play:hover { transform: scale(1.04); }
  .live-play .dot {
    width: 8px;
    height: 8px;
    border-radius: var(--r-full);
    background: var(--coral-500);
    box-shadow: 0 0 0 0 rgba(255, 87, 87, 0.6);
    animation: pulse 1.8s infinite;
  }
  .live-tag {
    position: absolute;
    top: var(--space-4);
    left: var(--space-4);
    z-index: 1;
    padding: 0.3rem 0.7rem;
    border-radius: var(--r-full);
    background: rgba(0, 0, 0, 0.45);
    color: #fff;
    font-size: var(--ft-xs);
    font-weight: var(--fw-medium);
    backdrop-filter: blur(6px);
  }
  @keyframes pulse {
    0% { box-shadow: 0 0 0 0 rgba(255, 87, 87, 0.6); }
    70% { box-shadow: 0 0 0 10px rgba(255, 87, 87, 0); }
    100% { box-shadow: 0 0 0 0 rgba(255, 87, 87, 0); }
  }
</style>
