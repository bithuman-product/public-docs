---
// Pagefind-powered search modal. The index (/pagefind/*) is generated by
// `pagefind --site dist` after `astro build`, so search works on the built
// site (Vercel preview/prod), not in `astro dev`. Lazy-loads the UI on open.
---

<div id="search-modal" class="sm" aria-hidden="true">
  <div class="sm-backdrop" data-sm-close></div>
  <div class="sm-panel" role="dialog" aria-modal="true" aria-label="Search docs">
    <div class="sm-head">
      <span class="sm-hint">Search the docs</span>
      <button class="sm-close" data-sm-close aria-label="Close search">Esc</button>
    </div>
    <div id="pf-search"></div>
  </div>
</div>

<script>
  let loaded = false;
  function loadPagefind(): Promise<void> {
    if (loaded) return Promise.resolve();
    loaded = true;
    return new Promise((resolve) => {
      const css = document.createElement("link");
      css.rel = "stylesheet";
      css.href = "/pagefind/pagefind-ui.css";
      document.head.appendChild(css);
      const s = document.createElement("script");
      s.src = "/pagefind/pagefind-ui.js";
      s.onload = () => {
        // @ts-ignore - injected global
        new window.PagefindUI({ element: "#pf-search", showSubResults: true, showImages: false, resetStyles: false });
        resolve();
      };
      s.onerror = () => {
        document.getElementById("pf-search")!.innerHTML =
          '<p style="padding:1rem;color:var(--color-text-secondary)">Search index is built at deploy time — try it on the preview/production site.</p>';
        resolve();
      };
      document.body.appendChild(s);
    });
  }
  const modal = document.getElementById("search-modal")!;
  async function open() {
    modal.classList.add("open");
    modal.setAttribute("aria-hidden", "false");
    await loadPagefind();
    (document.querySelector("#pf-search input") as HTMLInputElement | null)?.focus();
  }
  function close() {
    modal.classList.remove("open");
    modal.setAttribute("aria-hidden", "true");
  }
  (window as any).__bhOpenSearch = open;
  modal.querySelectorAll("[data-sm-close]").forEach((el) => el.addEventListener("click", close));
  document.addEventListener("keydown", (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === "k") {
      e.preventDefault();
      open();
    } else if (e.key === "Escape") {
      close();
    }
  });
</script>

<style>
  .sm { position: fixed; inset: 0; z-index: 200; display: none; }
  .sm.open { display: block; }
  .sm-backdrop { position: absolute; inset: 0; background: rgba(10, 10, 14, 0.5); backdrop-filter: blur(3px); }
  .sm-panel {
    position: relative;
    max-width: 600px;
    margin: 10vh auto 0;
    background: var(--color-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--r-xl);
    box-shadow: var(--shadow-lg);
    overflow: hidden;
  }
  .sm-head { display: flex; align-items: center; justify-content: space-between; padding: 0.6rem 0.9rem; border-bottom: 1px solid var(--color-border); }
  .sm-hint { font-size: var(--ft-xs); text-transform: uppercase; letter-spacing: 0.06em; color: var(--color-text-tertiary); }
  .sm-close { font-size: var(--ft-xs); color: var(--color-text-tertiary); background: var(--color-surface-2); border: 1px solid var(--color-border); border-radius: var(--r-sm); padding: 0.2rem 0.45rem; }
  #pf-search { padding: 0.9rem; --pagefind-ui-primary: var(--color-primary); --pagefind-ui-font: var(--font-sans); --pagefind-ui-background: var(--color-elevated); --pagefind-ui-text: var(--color-text); --pagefind-ui-border: var(--color-border); }
</style>
