---
// Swipe gallery of real gallery agents. Large panels, arrow + touch/drag swipe.
// Each panel lazy-loads a live, talkable embed on "Try live"; it can be closed
// manually (×) and AUTO-CLOSES when the user swipes it out of view. The embed
// URL already carries ?model=expression|essence per the source set.
interface Agent {
  code: string; name: string; group: string; model: string;
  kind: string; gender: string; category: string; image: string; embed: string;
}
interface Props { agents: Agent[]; filters?: boolean; }
const { agents, filters = false } = Astro.props;
---

<div class="scz" data-scz>
  {
    filters && (
      <div class="scz-filters" data-scz-filters>
        <div class="scz-fg" data-facet="group">
          <button class="scz-chip active" data-val="all">All</button>
          <button class="scz-chip" data-val="expression">Expression</button>
          <button class="scz-chip" data-val="essence">Essence</button>
        </div>
        <div class="scz-fg" data-facet="kind">
          <button class="scz-chip active" data-val="all">All types</button>
          <button class="scz-chip" data-val="human">People</button>
          <button class="scz-chip" data-val="animal">Animals</button>
        </div>
      </div>
    )
  }

  <div class="scz-wrap">
    <button class="scz-arrow prev" data-scz-prev aria-label="Previous">
      <svg width="20" height="20" viewBox="0 0 20 20"><path d="M12 4l-6 6 6 6" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </button>
    <div class="scz-track" data-scz-track>
      {
        agents.map((a) => (
          <div class="scz-panel" data-group={a.group} data-kind={a.kind} data-embed={a.embed}>
            <div class="scz-media">
              <img src={a.image} alt={a.name} loading="lazy" />
              <span class="scz-badge">{a.group === "expression" ? "Expression" : "Essence"}</span>
              <button class="scz-close" data-scz-close aria-label="Close live demo">
                <svg width="16" height="16" viewBox="0 0 16 16"><path d="M4 4l8 8M12 4l-8 8" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/></svg>
              </button>
              <div class="scz-overlay">
                <h3>{a.name}</h3>
                <p>{a.category} · {a.kind === "animal" ? "Animal" : "Human"}</p>
                <button class="scz-try" data-scz-try>
                  <span class="dot"></span> Try live
                </button>
              </div>
            </div>
          </div>
        ))
      }
    </div>
    <button class="scz-arrow next" data-scz-next aria-label="Next">
      <svg width="20" height="20" viewBox="0 0 20 20"><path d="M8 4l6 6-6 6" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </button>
  </div>
  <p class="scz-empty" data-scz-empty hidden>No agents match these filters.</p>
</div>

<script>
  document.querySelectorAll("[data-scz]").forEach((root) => {
    const track = root.querySelector("[data-scz-track]") as HTMLElement;
    const panels = Array.from(root.querySelectorAll(".scz-panel")) as HTMLElement[];

    const openLive = (panel: HTMLElement) => {
      if (panel.classList.contains("live")) return;
      const media = panel.querySelector(".scz-media")!;
      const f = document.createElement("iframe");
      f.src = panel.dataset.embed!;
      f.allow = "microphone; camera; autoplay; clipboard-write";
      f.title = "bitHuman live avatar";
      f.className = "scz-frame";
      media.appendChild(f);
      panel.classList.add("live");
    };
    const closeLive = (panel: HTMLElement) => {
      const f = panel.querySelector(".scz-frame");
      if (f) f.remove();
      panel.classList.remove("live");
    };

    panels.forEach((p) => {
      p.querySelector("[data-scz-try]")?.addEventListener("click", () => openLive(p));
      p.querySelector("[data-scz-close]")?.addEventListener("click", () => closeLive(p));
    });

    // auto-close a live panel once it is swiped mostly out of view
    if ("IntersectionObserver" in window) {
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            const p = e.target as HTMLElement;
            if (p.classList.contains("live") && e.intersectionRatio < 0.55) closeLive(p);
          });
        },
        { root: track, threshold: [0, 0.55, 0.9] }
      );
      panels.forEach((p) => io.observe(p));
    }

    // arrows
    const step = () => {
      const first = panels.find((p) => p.style.display !== "none");
      return first ? first.getBoundingClientRect().width + 20 : 360;
    };
    root.querySelector("[data-scz-prev]")?.addEventListener("click", () =>
      track.scrollBy({ left: -step(), behavior: "smooth" })
    );
    root.querySelector("[data-scz-next]")?.addEventListener("click", () =>
      track.scrollBy({ left: step(), behavior: "smooth" })
    );

    // filters
    const bar = root.querySelector("[data-scz-filters]");
    if (bar) {
      const state: Record<string, string> = { group: "all", kind: "all" };
      bar.querySelectorAll(".scz-chip").forEach((chip) =>
        chip.addEventListener("click", () => {
          const facet = (chip.closest(".scz-fg") as HTMLElement).dataset.facet!;
          state[facet] = (chip as HTMLElement).dataset.val!;
          bar.querySelectorAll(`.scz-fg[data-facet="${facet}"] .scz-chip`).forEach((c) =>
            c.classList.toggle("active", c === chip)
          );
          let shown = 0;
          panels.forEach((p) => {
            const ok =
              (state.group === "all" || p.dataset.group === state.group) &&
              (state.kind === "all" || p.dataset.kind === state.kind);
            p.style.display = ok ? "" : "none";
            if (!ok) closeLive(p);
            if (ok) shown++;
          });
          const empty = root.querySelector("[data-scz-empty]") as HTMLElement;
          if (empty) empty.hidden = shown !== 0;
          track.scrollTo({ left: 0 });
        })
      );
    }
  });
</script>

<style>
  .scz-filters { display: flex; gap: var(--space-4); flex-wrap: wrap; margin-bottom: var(--space-5); }
  .scz-fg { display: flex; gap: 0.3rem; }
  .scz-chip { padding: 0.35rem 0.85rem; border-radius: var(--r-full); border: 1px solid var(--color-border); background: var(--color-surface); color: var(--color-text-secondary); font-size: var(--ft-sm); font-weight: var(--fw-medium); transition: all var(--t-fast) var(--ease); }
  .scz-chip:hover { border-color: var(--color-border-strong); color: var(--color-text); }
  .scz-chip.active { background: var(--color-text); color: var(--color-bg); border-color: transparent; }

  .scz-wrap { position: relative; }
  .scz-track {
    display: flex; gap: 20px; overflow-x: auto; scroll-snap-type: x mandatory;
    padding: 4px 2px 16px; scrollbar-width: none; -webkit-overflow-scrolling: touch;
  }
  .scz-track::-webkit-scrollbar { display: none; }
  .scz-panel {
    flex: 0 0 auto; width: clamp(280px, 72vw, 360px); scroll-snap-align: center;
  }
  .scz-media {
    position: relative; aspect-ratio: 3 / 4; border-radius: var(--r-2xl); overflow: hidden;
    border: 1px solid var(--color-border); background: var(--color-surface-3); box-shadow: var(--shadow-md);
  }
  .scz-media img { width: 100%; height: 100%; object-fit: cover; }
  .scz-media :global(.scz-frame) { position: absolute; inset: 0; width: 100%; height: 100%; border: 0; }
  .scz-overlay {
    position: absolute; inset: 0; display: flex; flex-direction: column; justify-content: flex-end;
    gap: 0.3rem; padding: var(--space-5);
    background: linear-gradient(180deg, transparent 45%, rgba(0,0,0,0.72));
    color: #fff;
  }
  .scz-overlay h3 { color: #fff; font-size: var(--fh-md); }
  .scz-overlay p { color: rgba(255,255,255,0.82); font-size: var(--ft-sm); }
  .scz-try {
    align-self: flex-start; margin-top: var(--space-3); display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 0.6rem 1.15rem; border: 0; border-radius: var(--r-full); background: #fff; color: #111;
    font-weight: var(--fw-medium); box-shadow: var(--shadow-md); transition: transform var(--t-fast) var(--ease);
  }
  .scz-try:hover { transform: scale(1.04); }
  .scz-try .dot { width: 8px; height: 8px; border-radius: var(--r-full); background: var(--coral-500); animation: pulse 1.8s infinite; }
  .scz-badge { position: absolute; top: var(--space-4); left: var(--space-4); padding: 0.25rem 0.65rem; border-radius: var(--r-full); background: rgba(0,0,0,0.5); color: #fff; font-size: var(--ft-xs); font-weight: var(--fw-medium); backdrop-filter: blur(6px); }
  .scz-close { position: absolute; top: var(--space-4); right: var(--space-4); display: none; width: 32px; height: 32px; align-items: center; justify-content: center; border: 0; border-radius: var(--r-full); background: rgba(0,0,0,0.6); color: #fff; z-index: 2; }
  .scz-close:hover { background: rgba(0,0,0,0.85); }
  .scz-panel.live .scz-overlay, .scz-panel.live .scz-badge { display: none; }
  .scz-panel.live .scz-close { display: inline-flex; }

  .scz-arrow {
    position: absolute; top: calc(50% - 20px); transform: translateY(-50%); z-index: 3;
    width: 44px; height: 44px; display: grid; place-items: center; border-radius: var(--r-full);
    border: 1px solid var(--color-border); background: var(--color-elevated); color: var(--color-text);
    box-shadow: var(--shadow-md); transition: all var(--t-fast) var(--ease);
  }
  .scz-arrow:hover { border-color: var(--color-primary); color: var(--color-primary); }
  .scz-arrow.prev { left: -10px; }
  .scz-arrow.next { right: -10px; }
  .scz-empty { text-align: center; color: var(--color-text-secondary); padding: var(--space-8); }
  @media (max-width: 700px) { .scz-arrow { display: none; } .scz-panel { width: 80vw; } }
  @keyframes pulse { 0% { box-shadow: 0 0 0 0 rgba(255,87,87,0.6); } 70% { box-shadow: 0 0 0 9px rgba(255,87,87,0); } 100% { box-shadow: 0 0 0 0 rgba(255,87,87,0); } }
</style>
