---
const cols = [
  {
    title: "Platform",
    links: [
      { label: "API Platform", href: "/api" },
      { label: "CLI", href: "/cli" },
      { label: "Apps SDK", href: "/sdk" },
      { label: "Showcase", href: "/showcase" },
    ],
  },
  {
    title: "Develop",
    links: [
      { label: "Quickstart", href: "/api/quickstart" },
      { label: "Examples", href: "/examples" },
      { label: "API reference", href: "/api/reference" },
      { label: "Downloads", href: "/downloads" },
    ],
  },
  {
    title: "Resources",
    links: [
      { label: "Showcase", href: "/showcase" },
      { label: "Changelog", href: "/changelog" },
      { label: "Status", href: "https://status.bithuman.ai" },
      { label: "Pricing", href: "https://bithuman.ai/#pricing" },
    ],
  },
  {
    title: "Community",
    links: [
      { label: "Discord", href: "https://discord.gg/ES953n7bPA" },
      { label: "GitHub", href: "https://github.com/bithuman-product" },
      { label: "X / Twitter", href: "https://x.com/bithuman_ai" },
      { label: "Support", href: "/community" },
    ],
  },
];
const year = 2026;
---

<footer class="footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <a class="brand" href="https://www.bithuman.ai">
        <img src="/images/bitHuman-logo-circle.png" alt="" width="26" height="26" />
        <span>bitHuman</span>
      </a>
      <p class="muted">
        Real-time, on-device avatars. Audio in, lifelike face out — at 25 FPS,
        from Raspberry Pi to H100.
      </p>
    </div>
    <div class="footer-cols">
      {
        cols.map((c) => (
          <div class="footer-col">
            <h4>{c.title}</h4>
            {c.links.map((l) => (
              <a href={l.href}>{l.label}</a>
            ))}
          </div>
        ))
      }
    </div>
  </div>
  <div class="container footer-base">
    <span class="muted">© {year} bitHuman. All rights reserved.</span>
    <div class="footer-base-links">
      <a href="https://bithuman.ai/privacy">Privacy</a>
      <a href="https://bithuman.ai/terms">Terms</a>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--color-border);
    background: var(--color-surface-2);
    margin-top: var(--space-12);
  }
  .footer-inner {
    display: grid;
    grid-template-columns: 1.3fr 2.2fr;
    gap: var(--space-8);
    padding-block: var(--space-10) var(--space-8);
  }
  .footer-brand .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: var(--fw-bold);
    font-size: var(--ft-lg);
  }
  .footer-brand .brand img { border-radius: 6px; }
  .footer-brand p { margin-top: var(--space-3); max-width: 34ch; font-size: var(--ft-sm); }
  .footer-cols {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-5);
  }
  .footer-col h4 {
    font-size: var(--ft-xs);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-tertiary);
    margin-bottom: var(--space-3);
  }
  .footer-col a {
    display: block;
    padding: 0.28rem 0;
    font-size: var(--ft-sm);
    color: var(--color-text-secondary);
  }
  .footer-col a:hover { color: var(--color-primary); }
  .footer-base {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-block: var(--space-5);
    border-top: 1px solid var(--color-border);
    font-size: var(--ft-sm);
  }
  .footer-base-links { display: flex; gap: var(--space-5); }
  .footer-base-links a { color: var(--color-text-secondary); }
  .footer-base-links a:hover { color: var(--color-text); }

  @media (max-width: 860px) {
    .footer-inner { grid-template-columns: 1fr; gap: var(--space-6); }
    .footer-cols { grid-template-columns: repeat(2, 1fr); gap: var(--space-6); }
  }
</style>
