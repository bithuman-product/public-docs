---
import Hub from "../../components/Hub.astro";

const groups = [
  {
    label: "Get started",
    featured: true,
    cards: [
      { title: "Quickstart", desc: "Make your first API call and drive a live agent in minutes.", href: "/api/quickstart" },
      { title: "Authentication", desc: "API secrets, runtime tokens, and per-SDK key setup.", href: "/api/authentication" },
    ],
  },
  {
    label: "Agents",
    cards: [
      { title: "Agents", desc: "Generate, resolve, update, and drive agents — speak & add context.", href: "/api/agents" },
      { title: "Embedding", desc: "Mint embed tokens and drop a live agent into any page.", href: "/api/embedding" },
      { title: "Billing", desc: "Credit summaries and the realtime usage model.", href: "/api/billing" },
    ],
  },
  {
    label: "Reference",
    cards: [
      { title: "API reference", desc: "Full, interactive endpoint reference with try-it-out.", href: "/api/reference", badge: "Interactive" },
      { title: "Rate limits", desc: "Quotas and limits per endpoint.", href: "/api/rate-limits" },
      { title: "Overview", desc: "How the REST platform fits together.", href: "/api/overview" },
    ],
  },
];
---
<Hub
  eyebrow="API Platform"
  title="API Platform"
  tagline="Generate, manage, and animate realtime visual agents over REST — voice, dynamics, files, and embedding, all from api.bithuman.ai."
  ctas={[{ label: "Quickstart", href: "/api/quickstart" }, { label: "API reference", href: "/api/reference", variant: "secondary" }]}
  groups={groups}
/>
