---
import Base from "../layouts/Base.astro";
import Button from "../components/Button.astro";
import CodeTabs from "../components/CodeTabs.astro";
import Playground from "../components/Playground.astro";
import WidgetDemo from "../components/WidgetDemo.astro";
import caseStudies from "../data/case-studies.json";

const featuredCases = caseStudies.slice(0, 3);

const pillars = [
  { name: "API Platform", href: "/api", tag: "Generate, manage, and animate agents over REST — dynamics, embedding, and files from one API.", icon: "M4 7h16M4 12h16M4 17h10" },
  { name: "CLI", href: "/cli", tag: "Run a realtime visual agent from a single command — cloud or fully on-device, no GPU required.", icon: "M5 6l4 4-4 4M11 14h6" },
  { name: "Apps SDK", href: "/sdk", tag: "Embed lifelike agents natively — Python, Swift, Android, and the browser, all on one engine.", icon: "M12 3l8 4.5v9L12 21l-8-4.5v-9zM12 12l8-4.5M12 12v9M12 12L4 7.5" },
];

// elegant device icons (line-art, theme-aware via currentColor)
const devices = [
  { label: "iPhone", svg: `<rect x="7" y="2" width="10" height="20" rx="2.5"/><line x1="10.5" y1="4.6" x2="13.5" y2="4.6"/>` },
  { label: "Android", svg: `<path d="M5.5 11a6.5 6.5 0 0 1 13 0v6.5h-13z"/><line x1="7.5" y1="6" x2="6" y2="3.5"/><line x1="16.5" y1="6" x2="18" y2="3.5"/><circle cx="9.8" cy="10.5" r=".55" fill="currentColor" stroke="none"/><circle cx="14.2" cy="10.5" r=".55" fill="currentColor" stroke="none"/>` },
  { label: "Raspberry Pi", svg: `<rect x="3" y="6" width="18" height="12" rx="1.5"/><rect x="5.5" y="9" width="4" height="4" rx=".5"/><line x1="12.5" y1="9.5" x2="18" y2="9.5"/><line x1="12.5" y1="12" x2="18" y2="12"/><line x1="12.5" y1="14.5" x2="18" y2="14.5"/>` },
  { label: "Mac mini", svg: `<rect x="3" y="8" width="18" height="8" rx="1.5"/><circle cx="17" cy="12" r=".9"/>` },
  { label: "Browser", svg: `<rect x="3" y="4" width="18" height="16" rx="2"/><line x1="3" y1="8.5" x2="21" y2="8.5"/><circle cx="6" cy="6.2" r=".5" fill="currentColor" stroke="none"/><circle cx="8" cy="6.2" r=".5" fill="currentColor" stroke="none"/>` },
  { label: "Cloud", svg: `<path d="M7.5 18a4 4 0 0 1 .3-8 5 5 0 0 1 9.4-1A3.6 3.6 0 0 1 17 18z"/>` },
];

const stats = [
  { v: "Realtime", l: "lifelike lip-sync" },
  { v: "100+ FPS", l: "up to 1000+ on high-end" },
  { v: "On-device", l: "works offline" },
];

const quickstart = [
  { label: "CLI", lang: "bash", code: `curl -fsSL https://raw.githubusercontent.com/bithuman-product/homebrew-bithuman/main/install.sh | sh
bithuman pull modern-court-jester
bithuman run     # -> a live agent at http://127.0.0.1:8088` },
  { label: "Python", lang: "python", code: `from bithuman import AsyncBithuman

avatar = await AsyncBithuman.create(model_path="agent.imx", api_secret="bh_...")
await avatar.push_audio(pcm_bytes, 16000)   # 16 kHz int16 PCM (ends the utterance)
async for frame in avatar.run():
    render(frame.bgr_image)        # lifelike animated face, in realtime` },
  { label: "Swift", lang: "swift", code: `import bitHumanKit

let runtime = try await Bithuman.createRuntime(modelPath: imxURL)
try runtime.pushAudio(pcm16kMono)  // 16 kHz mono PCM
for await frame in runtime.frames() {
    view.render(frame.cgImage())   // on-device, realtime
}` },
];

const examples = [
  { t: "Hello, avatar (Python)", d: "Stream audio and render frames in ~20 lines.", href: "/examples/python-hello" },
  { t: "Voice agent + avatar", d: "A realtime conversational agent with a live face.", href: "/examples/ai-conversation" },
  { t: "REST in any language", d: "Generate and drive an agent over plain HTTP.", href: "/examples/rest-hello" },
];

// Real customers (logos copied into /public/logos) — monochrome credibility strip.
const customerLogos = [
  { name: "Shopify", src: "/logos/shopify-logo.svg" },
  { name: "Uber", src: "/logos/uber-logo.svg" },
  { name: "Allbirds", src: "/logos/allbirds-logo.svg" },
  { name: "Ivoclar", src: "/logos/ivoclar-logo.svg" },
  { name: "MINT Museum", src: "/logos/mint-museum-logo.webp" },
  { name: "NRF", src: "/logos/nrf-logo.webp" },
];
---

<Base>
  <!-- ===== HERO ===== -->
  <section class="hero">
    <div class="container">
      <div class="hero-grid">
        <!-- LEFT: value prop + CTA -->
        <div class="hero-copy">
          <span class="eyebrow" data-reveal>Realtime Visual AI</span>
          <h1 data-reveal>Realtime visual agents</h1>
          <p class="sub" data-reveal>Lifelike avatars that see, hear, and respond — live. Build them in a few lines of code, then run them anywhere: CPU, Apple Silicon, the browser, or the edge.</p>
          <div class="hero-cta" data-reveal>
            <Button href="/api/quickstart" size="lg">Start building</Button>
            <Button href="/showcase" variant="secondary" size="lg">Browse showcase</Button>
          </div>

          <!-- elegant device strip -->
          <div class="devices" data-reveal>
            {devices.map((d) => (
              <div class="device">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><Fragment set:html={d.svg} /></svg>
                <span>{d.label}</span>
              </div>
            ))}
          </div>

          <div class="hero-stats" data-reveal>
            {stats.map((s) => (<div class="stat"><strong>{s.v}</strong><span>{s.l}</span></div>))}
          </div>
        </div>

        <!-- RIGHT: live product moment (poster-first, iframe deferred to Launch) -->
        <div class="hero-media" data-reveal>
          <Playground compact />
        </div>
      </div>

      <!-- monochrome customer logo strip -->
      <div class="logo-strip" data-reveal>
        <span class="logo-strip-label">Trusted by teams shipping live agents</span>
        <div class="logo-row">
          {customerLogos.map((c) => (
            <img class="logo-item" src={c.src} alt={c.name} loading="lazy" decoding="async" width="96" height="28" />
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ===== PILLARS ===== -->
  <section class="section">
    <div class="container">
      <div class="pillars">
        {pillars.map((p) => (
          <a href={p.href} class="pillar" data-reveal>
            <div class="pillar-ico"><svg width="22" height="22" viewBox="0 0 24 24"><path d={p.icon} fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
            <h3>{p.name}</h3><p>{p.tag}</p><span class="pillar-go">Learn more →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== MODELS (upfront) ===== -->
  <section class="section">
    <div class="container">
      <div class="section-head" data-reveal>
        <span class="eyebrow">Two models, one SDK</span>
        <h2>Essence &amp; Expression</h2>
        <p>Start with Essence; reach for Expression when you need to animate any face.</p>
      </div>
      <div class="cards-2">
        <a class="mcard" href="/concepts/models" data-reveal>
          <div class="mcard-top"><h3>Essence</h3><span class="pill model-tag">Default · on-device</span></div>
          <p>A pre-built identity in a portable .imx — runs in realtime on CPU, Apple Silicon, and the browser (WASM). Lowest cost, works offline.</p>
          <span class="mlink">Learn more →</span>
        </a>
        <a class="mcard" href="/concepts/models" data-reveal>
          <div class="mcard-top"><h3>Expression</h3><span class="pill model-tag">Animate any face</span></div>
          <p>Turns any portrait into an expressive, talking agent at runtime with AI facial dynamics. Runs on a GPU or recent Apple Silicon.</p>
          <span class="mlink">Learn more →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ===== QUICKSTART ===== -->
  <section class="section quickstart-sec">
    <div class="container qs-grid">
      <div class="qs-copy" data-reveal>
        <span class="eyebrow">Quickstart</span>
        <h2>Your first agent in two minutes</h2>
        <p class="muted">Install once, then drive a live agent from the CLI, Python, Swift, or plain REST.</p>
        <Button href="/api/quickstart">Full quickstart →</Button>
      </div>
      <div data-reveal><CodeTabs tabs={quickstart} title="Quickstart" /></div>
    </div>
  </section>

  <!-- ===== TRY IT (WYSIWYG playground) ===== -->
  <section class="section tryit-sec">
    <div class="container">
      <div class="section-head" data-reveal>
        <span class="eyebrow">Try it</span>
        <h2>Edit, then launch a live agent</h2>
        <p>Pick an agent and model — the embed code updates live. Hit <strong>Launch</strong> to talk to it, right here.</p>
      </div>
      <div data-reveal><Playground /></div>
    </div>
  </section>

  <!-- ===== EMBED WIDGET ===== -->
  <section class="section">
    <div class="container">
      <div class="section-head" data-reveal>
        <span class="eyebrow">Embed anywhere</span>
        <h2>Drop an agent into any site</h2>
        <p>One line of HTML adds a live agent — pick a corner gadget or a full chat widget, then try both right here.</p>
      </div>
      <div data-reveal><WidgetDemo /></div>
    </div>
  </section>

  <!-- ===== EXAMPLES ===== -->
  <section class="section">
    <div class="container">
      <div class="section-head show-head" data-reveal>
        <div><span class="eyebrow">Examples</span><h2>Copy-paste starting points</h2></div>
        <Button href="/examples" variant="secondary">All examples</Button>
      </div>
      <div class="cards-3">
        {examples.map((e) => (<a class="ecard" href={e.href} data-reveal><h3>{e.t}</h3><p>{e.d}</p><span class="mlink">Open →</span></a>))}
      </div>
    </div>
  </section>

  <!-- ===== SHOWCASE (case studies) ===== -->
  <section class="section">
    <div class="container">
      <div class="section-head show-head" data-reveal>
        <div><span class="eyebrow">Showcase</span><h2>Built with bitHuman</h2><p>Real teams shipping realtime visual agents into the world.</p></div>
        <Button href="/showcase" variant="secondary">See all</Button>
      </div>
      <div class="cards-3">
        {featuredCases.map((c) => (
          <a class="bcard" href="/showcase" data-reveal>
            <div class="bcard-img" style={`background-image:url(${c.image})`}>
              <span class="bcard-org">{c.org}</span>
            </div>
            <div class="bcard-b">
              <span class="pill">{c.category}</span>
              <h3>{c.title}</h3>
              <p>{c.summary}</p>
              {c.metric && (
                <div class="bcard-metric">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                  <span>{c.metric}</span>
                </div>
              )}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== CTA ===== -->
  <section class="section">
    <div class="container">
      <div class="cta" data-reveal>
        <h2>Ship your first visual agent today</h2>
        <p>Free tier — 99 credits a month, no card required.</p>
        <div class="cta-actions">
          <Button href="https://bithuman.ai/#developer" size="lg" external>Get your API key</Button>
          <Button href="/api/quickstart" variant="secondary" size="lg">Read the quickstart</Button>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .hero { padding-block: var(--space-12) var(--space-10); }
  .hero-grid { display: grid; grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr); gap: var(--space-8); align-items: center; }
  .hero-copy { display: flex; flex-direction: column; align-items: flex-start; }
  .hero-copy .eyebrow { margin-bottom: var(--space-3); }
  .hero h1 { font-size: clamp(2.6rem, 5.2vw, var(--fh-4xl)); }
  .hero .sub { margin: var(--space-4) 0 0; font-size: var(--ft-xl); color: var(--color-text-secondary); max-width: 34ch; }
  .hero-cta { display: flex; gap: var(--space-3); margin-top: var(--space-6); flex-wrap: wrap; }
  .hero-media { min-width: 0; }

  /* elegant device strip */
  .devices { display: flex; flex-wrap: wrap; gap: var(--space-6); margin-top: var(--space-8); }
  .device { display: flex; flex-direction: column; align-items: center; gap: 0.5rem; color: var(--color-text-tertiary); transition: color var(--t-fast) var(--ease); }
  .device:hover { color: var(--color-primary); }
  .device svg { width: 34px; height: 34px; }
  .device span { font-size: var(--ft-xs); font-weight: var(--fw-medium); }

  .hero-stats { display: flex; gap: var(--space-8); margin-top: var(--space-8); flex-wrap: wrap; }
  .stat { display: flex; flex-direction: column; }
  .stat strong { font-size: var(--fh-md); letter-spacing: -0.02em; }
  .stat span { font-size: var(--ft-sm); color: var(--color-text-tertiary); }

  /* monochrome customer logo strip */
  .logo-strip { margin-top: var(--space-10); padding-top: var(--space-8); border-top: 1px solid var(--color-border); text-align: center; }
  .logo-strip-label { display: block; font-size: var(--ft-xs); font-weight: var(--fw-medium); letter-spacing: 0.06em; text-transform: uppercase; color: var(--color-text-tertiary); margin-bottom: var(--space-5); }
  .logo-row { display: flex; flex-wrap: wrap; align-items: center; justify-content: center; gap: var(--space-8) var(--space-10); }
  .logo-item { height: 26px; width: auto; max-width: 120px; object-fit: contain; opacity: 0.55; filter: grayscale(1); transition: opacity var(--t-fast) var(--ease), filter var(--t-fast) var(--ease); }
  .logo-item:hover { opacity: 0.95; filter: grayscale(0); }

  .pillars { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-5); }
  .pillar { display: flex; flex-direction: column; padding: var(--space-6); border: 1px solid var(--color-border); border-radius: var(--r-2xl); background: var(--color-surface); transition: all var(--t-med) var(--ease); }
  .pillar:hover { border-color: var(--color-primary); transform: translateY(-2px); box-shadow: var(--shadow-md); }
  .pillar-ico { width: 44px; height: 44px; display: grid; place-items: center; border-radius: var(--r-lg); background: var(--color-primary-soft); color: var(--color-primary); margin-bottom: var(--space-4); }
  .pillar h3 { font-size: var(--fh-md); }
  .pillar p { margin-top: var(--space-2); color: var(--color-text-secondary); font-size: var(--ft-sm); flex: 1; }
  .pillar-go { margin-top: var(--space-4); color: var(--color-primary); font-weight: var(--fw-medium); font-size: var(--ft-sm); }

  .section-head { max-width: 720px; margin-bottom: var(--space-6); }
  .section-head h2 { font-size: var(--fh-2xl); margin-top: var(--space-3); }
  .section-head p { margin-top: var(--space-3); font-size: var(--ft-lg); color: var(--color-text-secondary); }

  .cards-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-5); }
  .cards-2 { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--space-5); }
  .mcard { display: block; padding: var(--space-6); border: 1px solid var(--color-border); border-radius: var(--r-2xl); background: var(--color-surface); transition: all var(--t-med) var(--ease); }
  .mcard:hover { border-color: var(--color-primary); transform: translateY(-2px); box-shadow: var(--shadow-md); }
  .mcard-top { display: flex; align-items: center; gap: var(--space-3); }
  .mcard-top h3 { font-size: var(--fh-md); }
  .model-tag { background: var(--color-primary-soft); color: var(--color-primary); border-color: transparent; }
  .mcard p { margin: var(--space-3) 0 var(--space-4); color: var(--color-text-secondary); }
  .mlink { color: var(--color-primary); font-weight: var(--fw-medium); font-size: var(--ft-sm); }

  .tryit-sec { background: var(--color-surface-2); border-block: 1px solid var(--color-border); }
  .qs-grid { display: grid; grid-template-columns: 0.8fr minmax(0, 1.2fr); gap: var(--space-8); align-items: center; }
  .qs-grid > * { min-width: 0; }
  .qs-copy h2 { font-size: var(--fh-xl); margin-top: var(--space-3); }
  .qs-copy .muted { margin: var(--space-3) 0 var(--space-5); font-size: var(--ft-lg); }

  .show-head { display: flex; justify-content: space-between; align-items: flex-end; max-width: none; gap: var(--space-5); }
  .bcard { border: 1px solid var(--color-border); border-radius: var(--r-xl); overflow: hidden; background: var(--color-surface); transition: transform var(--t-med) var(--ease), box-shadow var(--t-med) var(--ease); }
  .bcard:hover { transform: translateY(-3px); box-shadow: var(--shadow-md); }
  .bcard-img { position: relative; aspect-ratio: 16/10; background-size: cover; background-position: center; background-color: var(--color-surface-3); }
  .bcard-org { position: absolute; left: var(--space-3); bottom: var(--space-3); padding: 0.2rem 0.55rem; border-radius: var(--r-sm); background: rgba(0,0,0,0.62); color: #fff; font-size: var(--ft-xs); font-weight: var(--fw-medium); backdrop-filter: blur(2px); }
  .bcard-b { padding: var(--space-4); }
  .bcard-b .pill { margin-bottom: var(--space-2); }
  .bcard-b h3 { font-size: var(--ft-lg); }
  .bcard-b p { margin-top: 0.35rem; color: var(--color-text-secondary); font-size: var(--ft-sm); }
  .bcard-metric { display: inline-flex; align-items: center; gap: 0.4rem; margin-top: var(--space-3); padding: 0.3rem 0.6rem; border-radius: var(--r-full); background: var(--color-primary-soft); color: var(--color-primary); font-size: var(--ft-xs); font-weight: var(--fw-medium); }
  .bcard-metric svg { flex: none; }

  .ecard { display: block; padding: var(--space-5); border: 1px solid var(--color-border); border-radius: var(--r-xl); background: var(--color-surface); transition: all var(--t-med) var(--ease); }
  .ecard:hover { border-color: var(--color-primary); transform: translateY(-2px); box-shadow: var(--shadow-md); }
  .ecard h3 { font-size: var(--ft-lg); }
  .ecard p { margin: 0.35rem 0 var(--space-3); color: var(--color-text-secondary); font-size: var(--ft-sm); }

  .cta { text-align: center; padding: var(--space-10) var(--space-6); border: 1px solid var(--color-border); border-radius: var(--r-3xl); background: var(--color-surface-2); }
  .cta h2 { font-size: var(--fh-2xl); }
  .cta p { margin-top: var(--space-3); color: var(--color-text-secondary); font-size: var(--ft-lg); }
  .cta-actions { display: flex; gap: var(--space-3); justify-content: center; margin-top: var(--space-6); flex-wrap: wrap; }

  @media (max-width: 980px) {
    .qs-grid { grid-template-columns: 1fr; }
    .pillars, .cards-3 { grid-template-columns: 1fr; }
    .cards-2 { grid-template-columns: 1fr; }
    /* hero stacks: media first as the product moment, then copy */
    .hero-grid { grid-template-columns: 1fr; gap: var(--space-8); }
    .hero-media { order: -1; max-width: 560px; margin-inline: auto; width: 100%; }
    .hero-copy { align-items: center; text-align: center; }
    .hero .sub { max-width: 52ch; }
    .hero-cta, .devices, .hero-stats { justify-content: center; }
  }
  @media (max-width: 600px) {
    .devices { gap: var(--space-5); }
    .hero-stats { gap: var(--space-5); }
    .show-head { flex-direction: column; align-items: flex-start; }
    .logo-row { gap: var(--space-5) var(--space-6); }
    .logo-item { height: 22px; }
  }
</style>
