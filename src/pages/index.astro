---
import Base from "../layouts/Base.astro";
import Button from "../components/Button.astro";
import CodeTabs from "../components/CodeTabs.astro";
import ShowcaseCarousel from "../components/ShowcaseCarousel.astro";
import showcaseData from "../data/showcase-agents.json";

const featuredAgents = [
  ...showcaseData.expression.slice(0, 4),
  ...showcaseData.essence.slice(0, 4),
];

const pillars = [
  {
    name: "API Platform",
    href: "/api",
    tag: "Generate, manage, and animate agents over REST — voice, dynamics, and embedding from one API.",
    icon: "M4 7h16M4 12h16M4 17h10",
  },
  {
    name: "CLI",
    href: "/cli",
    tag: "Run a realtime visual agent from a single command — cloud or fully on-device, no GPU required.",
    icon: "M5 6l4 4-4 4M11 14h6",
  },
  {
    name: "Apps SDK",
    href: "/sdk",
    tag: "Embed lifelike agents natively — Python, Swift, Android, and the browser, all on one engine.",
    icon: "M12 3l8 4.5v9L12 21l-8-4.5v-9zM12 12l8-4.5M12 12v9M12 12L4 7.5",
  },
];

const devices = [
  "iPhone & iPad", "Android", "In the browser", "Raspberry Pi",
  "MacBook & Mac mini", "Windows PC", "Linux & Jetson", "Cloud GPU",
];

const quickstart = [
  { label: "CLI", lang: "bash", code: `brew install bithuman-cli
bithuman pull modern-court-jester
bithuman run     # -> a live avatar at http://127.0.0.1:8088` },
  { label: "Python", lang: "python", code: `from bithuman import AsyncBithuman

avatar = await AsyncBithuman.create(api_secret="bh_...", avatar_id="A74NWD9723")
avatar.push_audio(pcm_bytes, 16000); avatar.flush()
async for frame in avatar.run():
    render(frame.bgr_image)        # animated face @ 25 FPS` },
  { label: "Swift", lang: "swift", code: `import bitHumanKit

let avatar = try await Bithuman.createRuntime(modelPath: imxURL, apiKey: "bh_...")
for try await frame in avatar.run() {
    view.render(frame.image)       // on-device, sub-200ms
}` },
  { label: "cURL", lang: "bash", code: `curl https://api.bithuman.ai/v1/agent/A74NWD9723/speak \\
  -H "api-secret: $BITHUMAN_API_SECRET" \\
  -d '{"text":"Hello from bitHuman."}'` },
];

const useCases = [
  { t: "Realtime avatars", d: "Lifelike, lip-synced agents that respond live — at 25 FPS.", img: "/images/animals/koala.jpg" },
  { t: "Talking videos", d: "Generate scripted videos from a single face image.", img: "/images/animals/cat-hat.jpg" },
  { t: "AI books", d: "Characters, narration, and imagery woven into stories.", img: "/images/animals/rainbow-creature.jpg" },
  { t: "Embeddable agents", d: "Drop a live, talkable agent into any app or page.", img: "/images/animals/bunny-glasses.jpg" },
];

const caseStudies = [
  { t: "One photo. Infinite cinema.", d: "Turn any portrait into a talking, expressive character.", href: "/use-cases", img: "/images/animals/capybara.jpg" },
  { t: "AI books, alive", d: "Multi-character illustrated books that read themselves aloud.", href: "/use-cases", img: "/images/animals/fluffy-creature.jpg" },
  { t: "Agents on the edge", d: "Kiosks and devices running fully offline on a Raspberry Pi.", href: "/use-cases", img: "/images/example-raspberry-pi-device.jpg" },
];

const examples = [
  { t: "Hello, avatar (Python)", d: "Stream audio and render frames in ~20 lines.", href: "/examples/python-hello" },
  { t: "Voice agent + avatar", d: "OpenAI Realtime voice chat with a live face.", href: "/examples/ai-conversation" },
  { t: "REST in any language", d: "Generate and drive an agent over plain HTTP.", href: "/examples/rest-hello" },
];
---

<Base>
  <!-- ===== HERO (text-led, OpenAI-style) ===== -->
  <section class="hero">
    <div class="container">
      <h1 data-reveal>Realtime visual agents,<br />on every device.</h1>
      <p class="sub" data-reveal>
        bitHuman is the most cost-effective way to build lifelike, lip-synced AI
        agents — running on-device from a Raspberry Pi to an iPhone to the
        browser. Best-in-class quality, up to <strong>10× cheaper</strong> than
        the alternatives.
      </p>
      <div class="hero-cta" data-reveal>
        <Button href="/api/quickstart" size="lg">Start building</Button>
        <Button href="/showcase" variant="secondary" size="lg">Browse showcase</Button>
      </div>

      <!-- featured card -->
      <a class="feature" href="/sdk" data-reveal>
        <div class="feature-badge">
          <svg width="22" height="22" viewBox="0 0 24 24"><path d="M12 3l8 4.5v9L12 21l-8-4.5v-9zM12 12l8-4.5M12 12v9M12 12L4 7.5" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <div class="feature-body">
          <strong>One engine, every platform.</strong>
          <span>The same realtime avatar engine powers the CLI, every SDK, and the REST API — write once, run on-device or in the cloud.</span>
        </div>
        <span class="feature-go">Explore the SDKs →</span>
      </a>
    </div>
  </section>

  <!-- ===== PILLARS ===== -->
  <section class="section">
    <div class="container">
      <div class="pillars">
        {pillars.map((p) => (
          <a href={p.href} class="pillar" data-reveal>
            <div class="pillar-ico"><svg width="22" height="22" viewBox="0 0 24 24"><path d={p.icon} fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
            <h3>{p.name}</h3>
            <p>{p.tag}</p>
            <span class="pillar-go">Learn more →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== RUNS EVERYWHERE (positioning) ===== -->
  <section class="section runs">
    <div class="container">
      <div class="section-head" data-reveal>
        <span class="eyebrow">Runs everywhere</span>
        <h2>One lightweight engine. Any device.</h2>
        <p>From a $35 Raspberry Pi to an H100 — the same agent runs on-device, offline-capable, with no heavy GPU dependency. Cross-platform tools, a CLI, and native SDKs make it easy to ship.</p>
      </div>
      <div class="device-grid" data-reveal>
        {devices.map((d) => <span class="device">{d}</span>)}
      </div>
      <div class="stat-row" data-reveal>
        <div class="stat"><strong>25 FPS</strong><span>realtime lip-sync</span></div>
        <div class="stat"><strong>&lt;200 ms</strong><span>first frame</span></div>
        <div class="stat"><strong>10×</strong><span>cheaper than alternatives</span></div>
        <div class="stat"><strong>On-device</strong><span>offline-capable</span></div>
      </div>
    </div>
  </section>

  <!-- ===== QUICKSTART ===== -->
  <section class="section">
    <div class="container qs-grid">
      <div class="qs-copy" data-reveal>
        <span class="eyebrow">Quickstart</span>
        <h2>Your first agent in two minutes</h2>
        <p class="muted">Install once, then drive a live agent from the CLI, Python, Swift, or plain REST.</p>
        <Button href="/api/quickstart">Full quickstart →</Button>
      </div>
      <div data-reveal><CodeTabs tabs={quickstart} title="Quickstart" /></div>
    </div>
  </section>

  <!-- ===== USE CASES ===== -->
  <section class="section">
    <div class="container">
      <div class="section-head" data-reveal><span class="eyebrow">Use cases</span><h2>What you can build</h2></div>
      <div class="cards-4">
        {useCases.map((u) => (
          <div class="ucard" data-reveal>
            <div class="ucard-img" style={`background-image:url(${u.img})`}></div>
            <div class="ucard-b"><h3>{u.t}</h3><p>{u.d}</p></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== SHOWCASE (swipe gallery) ===== -->
  <section class="section showcase-sec">
    <div class="container">
      <div class="section-head show-head" data-reveal>
        <div><span class="eyebrow">Showcase</span><h2>Talk to a live agent</h2><p>Swipe through real agents — tap <strong>Try live</strong> to start a conversation.</p></div>
        <Button href="/showcase" variant="secondary">See all</Button>
      </div>
      <div data-reveal><ShowcaseCarousel agents={featuredAgents} /></div>
    </div>
  </section>

  <!-- ===== MODELS ===== -->
  <section class="section">
    <div class="container">
      <div class="section-head" data-reveal><span class="eyebrow">Models</span><h2>Essence &amp; Expression</h2><p>Two avatar models, one SDK. Start with Essence; reach for Expression to animate any face.</p></div>
      <div class="cards-2">
        <div class="mcard" data-reveal>
          <div class="mcard-top"><h3>Essence</h3><span class="pill model-tag">Default</span></div>
          <p>A pre-built identity in a portable .imx. Runs on CPU, Apple Silicon, and the browser (WASM) with low memory.</p>
          <a class="mlink" href="/concepts/models">Learn more →</a>
        </div>
        <div class="mcard" data-reveal>
          <div class="mcard-top"><h3>Expression</h3><span class="pill model-tag">Any face</span></div>
          <p>Animates any portrait at runtime with AI facial dynamics. Runs on a GPU or recent Apple Silicon.</p>
          <a class="mlink" href="/concepts/models">Learn more →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== CASE STUDIES ===== -->
  <section class="section">
    <div class="container">
      <div class="section-head show-head" data-reveal>
        <div><span class="eyebrow">Case studies</span><h2>Built with bitHuman</h2></div>
        <Button href="/use-cases" variant="secondary">View all</Button>
      </div>
      <div class="cards-3">
        {caseStudies.map((c) => (
          <a class="bcard" href={c.href} data-reveal>
            <div class="bcard-img" style={`background-image:url(${c.img})`}></div>
            <div class="bcard-b"><h3>{c.t}</h3><p>{c.d}</p></div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== EXAMPLES ===== -->
  <section class="section">
    <div class="container">
      <div class="section-head show-head" data-reveal>
        <div><span class="eyebrow">Examples</span><h2>Copy-paste starting points</h2></div>
        <Button href="/examples" variant="secondary">All examples</Button>
      </div>
      <div class="cards-3">
        {examples.map((e) => (
          <a class="ecard" href={e.href} data-reveal>
            <h3>{e.t}</h3><p>{e.d}</p><span class="mlink">Open →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== CTA ===== -->
  <section class="section">
    <div class="container">
      <div class="cta" data-reveal>
        <h2>Ship your first visual agent today</h2>
        <p>Free tier — 99 credits a month, no card required.</p>
        <div class="cta-actions">
          <Button href="https://bithuman.ai/#developer" size="lg" external>Get your API key</Button>
          <Button href="/api/quickstart" variant="secondary" size="lg">Read the quickstart</Button>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .hero { padding-block: var(--space-12) var(--space-8); }
  .hero h1 { font-size: clamp(2.7rem, 6vw, var(--fh-4xl)); max-width: 16ch; }
  .hero .sub { margin-top: var(--space-5); font-size: var(--ft-xl); color: var(--color-text-secondary); max-width: 60ch; }
  .hero-cta { display: flex; gap: var(--space-3); margin-top: var(--space-6); flex-wrap: wrap; }
  .feature { display: flex; align-items: center; gap: var(--space-4); margin-top: var(--space-8); padding: var(--space-5); border: 1px solid var(--color-border); border-radius: var(--r-2xl); background: var(--color-surface); transition: all var(--t-med) var(--ease); }
  .feature:hover { border-color: var(--color-primary); box-shadow: var(--shadow-md); }
  .feature-badge { flex: none; width: 48px; height: 48px; display: grid; place-items: center; border-radius: var(--r-lg); background: var(--color-primary-soft); color: var(--color-primary); }
  .feature-body { display: flex; flex-direction: column; gap: 0.2rem; }
  .feature-body strong { font-size: var(--ft-lg); }
  .feature-body span { color: var(--color-text-secondary); font-size: var(--ft-sm); }
  .feature-go { margin-left: auto; color: var(--color-primary); font-weight: var(--fw-medium); font-size: var(--ft-sm); white-space: nowrap; }

  .pillars { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-5); }
  .pillar { display: flex; flex-direction: column; padding: var(--space-6); border: 1px solid var(--color-border); border-radius: var(--r-2xl); background: var(--color-surface); transition: all var(--t-med) var(--ease); }
  .pillar:hover { border-color: var(--color-primary); transform: translateY(-2px); box-shadow: var(--shadow-md); }
  .pillar-ico { width: 44px; height: 44px; display: grid; place-items: center; border-radius: var(--r-lg); background: var(--color-primary-soft); color: var(--color-primary); margin-bottom: var(--space-4); }
  .pillar h3 { font-size: var(--fh-md); }
  .pillar p { margin-top: var(--space-2); color: var(--color-text-secondary); font-size: var(--ft-sm); flex: 1; }
  .pillar-go { margin-top: var(--space-4); color: var(--color-primary); font-weight: var(--fw-medium); font-size: var(--ft-sm); }

  .runs { background: var(--color-surface-2); border-block: 1px solid var(--color-border); }
  .device-grid { display: flex; flex-wrap: wrap; gap: 0.6rem; margin-top: var(--space-2); }
  .device { padding: 0.5rem 1rem; border-radius: var(--r-full); border: 1px solid var(--color-border); background: var(--color-surface); font-size: var(--ft-sm); font-weight: var(--fw-medium); color: var(--color-text-secondary); }
  .stat-row { display: flex; gap: var(--space-8); margin-top: var(--space-8); flex-wrap: wrap; }
  .stat { display: flex; flex-direction: column; }
  .stat strong { font-size: var(--fh-lg); letter-spacing: -0.02em; }
  .stat span { font-size: var(--ft-sm); color: var(--color-text-tertiary); }

  .qs-grid { display: grid; grid-template-columns: 0.8fr 1.2fr; gap: var(--space-8); align-items: center; }
  .qs-copy h2 { font-size: var(--fh-xl); margin-top: var(--space-3); }
  .qs-copy .muted { margin: var(--space-3) 0 var(--space-5); font-size: var(--ft-lg); }

  .cards-4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--space-5); }
  .cards-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-5); }
  .cards-2 { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--space-5); }
  .ucard, .bcard { border: 1px solid var(--color-border); border-radius: var(--r-xl); overflow: hidden; background: var(--color-surface); transition: transform var(--t-med) var(--ease), box-shadow var(--t-med) var(--ease); }
  .ucard:hover, .bcard:hover { transform: translateY(-3px); box-shadow: var(--shadow-md); }
  .ucard-img, .bcard-img { aspect-ratio: 16/10; background-size: cover; background-position: center; }
  .ucard-b, .bcard-b { padding: var(--space-4); }
  .ucard-b h3, .bcard-b h3 { font-size: var(--ft-lg); }
  .ucard-b p, .bcard-b p { margin-top: 0.35rem; color: var(--color-text-secondary); font-size: var(--ft-sm); }

  .mcard { padding: var(--space-6); border: 1px solid var(--color-border); border-radius: var(--r-2xl); background: var(--color-surface); }
  .mcard-top { display: flex; align-items: center; gap: var(--space-3); }
  .mcard-top h3 { font-size: var(--fh-md); }
  .model-tag { background: var(--color-primary-soft); color: var(--color-primary); border-color: transparent; }
  .mcard p { margin: var(--space-3) 0 var(--space-4); color: var(--color-text-secondary); }
  .mlink { color: var(--color-primary); font-weight: var(--fw-medium); font-size: var(--ft-sm); }

  .ecard { display: block; padding: var(--space-5); border: 1px solid var(--color-border); border-radius: var(--r-xl); background: var(--color-surface); transition: all var(--t-med) var(--ease); }
  .ecard:hover { border-color: var(--color-primary); transform: translateY(-2px); box-shadow: var(--shadow-md); }
  .ecard h3 { font-size: var(--ft-lg); }
  .ecard p { margin: 0.35rem 0 var(--space-3); color: var(--color-text-secondary); font-size: var(--ft-sm); }

  .showcase-sec { background: var(--color-surface-2); border-block: 1px solid var(--color-border); }
  .show-head { display: flex; justify-content: space-between; align-items: flex-end; max-width: none; gap: var(--space-5); }

  .cta { text-align: center; padding: var(--space-10) var(--space-6); border: 1px solid var(--color-border); border-radius: var(--r-3xl); background: var(--color-surface-2); }
  .cta h2 { font-size: var(--fh-2xl); }
  .cta p { margin-top: var(--space-3); color: var(--color-text-secondary); font-size: var(--ft-lg); }
  .cta-actions { display: flex; gap: var(--space-3); justify-content: center; margin-top: var(--space-6); flex-wrap: wrap; }

  @media (max-width: 980px) {
    .qs-grid { grid-template-columns: 1fr; }
    .pillars, .cards-3 { grid-template-columns: 1fr; }
    .cards-4 { grid-template-columns: repeat(2, 1fr); }
    .cards-2 { grid-template-columns: 1fr; }
    .feature { flex-direction: column; align-items: flex-start; }
    .feature-go { margin-left: 0; }
  }
  @media (max-width: 600px) { .cards-4 { grid-template-columns: 1fr; } .show-head { flex-direction: column; align-items: flex-start; } }
</style>
