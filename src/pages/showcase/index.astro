---
import Base from "../../layouts/Base.astro";
import ShowcaseGrid from "../../components/ShowcaseGrid.astro";
import data from "../../data/showcase-agents.json";

const agents = [...data.expression, ...data.essence];
---

<Base title="Showcase — bitHuman" description="Live, talkable demo agents built with bitHuman — Expression and Essence, human and animal.">
  <section class="sc-hero bg-grid">
    <div class="container">
      <span class="eyebrow">Showcase</span>
      <h1>Built with bitHuman</h1>
      <p class="lede">
        Real, talkable agents running on the bitHuman engine. Click <strong>Try live</strong>
        on any card to start a conversation — Expression animates a face at runtime,
        Essence streams a pre-built identity.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <ShowcaseGrid agents={agents} filters={true} />
    </div>
  </section>
</Base>

<style>
  .sc-hero { padding-block: var(--space-10) var(--space-6); border-bottom: 1px solid var(--color-border); }
  .sc-hero h1 { font-size: var(--fh-3xl); margin-top: var(--space-3); }
  .sc-hero .lede { margin-top: var(--space-4); font-size: var(--ft-xl); color: var(--color-text-secondary); max-width: 60ch; }
  .sc-hero .section, .section { padding-block: var(--space-8); }
</style>
