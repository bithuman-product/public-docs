---
import "../styles/global.css";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import Search from "../components/Search.astro";

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = "bitHuman Docs — Private On-Device AI Avatars in Real Time",
  description = "Build with bitHuman: turn a photo into a real-time (25 FPS) AI avatar that runs fully on-device. Private by design — audio, video, and prompts never leave your hardware. Self-host, deploy on-prem, or run air-gapped at the lowest per-minute cost.",
  image = "/images/bithuman-banner.jpg",
} = Astro.props;

const site = Astro.site ?? new URL("https://docs.bithuman.ai");
const canonical = new URL(Astro.url.pathname, site).href;
const ogImage = new URL(image, site).href;
---

<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/bithuman-mark.png" />

    <!-- Open Graph / Twitter -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="bitHuman Docs" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- JSON-LD: Organization + SoftwareApplication (site-wide structured data) -->
    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Organization",
          "@id": "https://www.bithuman.ai/#organization",
          "name": "bitHuman",
          "url": "https://www.bithuman.ai",
          "logo": "https://docs.bithuman.ai/bithuman-mark.png",
          "description": "bitHuman builds private, on-device AI avatars that turn any photo into a real-time video agent — self-hostable, deployable on-prem, and able to run fully air-gapped."
        },
        {
          "@type": "SoftwareApplication",
          "@id": "https://www.bithuman.ai/#software",
          "name": "bitHuman",
          "applicationCategory": "DeveloperApplication",
          "operatingSystem": "macOS, Linux, iOS, iPadOS, Raspberry Pi OS",
          "url": "https://www.bithuman.ai",
          "publisher": { "@id": "https://www.bithuman.ai/#organization" },
          "description": "On-device AI avatar runtime and SDKs. Turn a photo into a real-time (25 FPS) avatar that runs fully on your own hardware — private by design, self-hostable, on-prem, and air-gapped-capable. Runs on CPU (including Raspberry Pi), NVIDIA GPU, and Apple Silicon.",
          "featureList": [
            "On-device inference — audio, video, and prompts never leave your hardware",
            "Real-time 25 FPS lip-sync",
            "Runs on CPU (incl. Raspberry Pi), NVIDIA GPU, and Apple Silicon",
            "Self-hosted, on-prem, and air-gapped deployment",
            "Low per-minute cost, from 1 credit/min self-hosted"
          ],
          "offers": {
            "@type": "Offer",
            "price": "0",
            "priceCurrency": "USD",
            "description": "Free tier available; low per-minute cost from 1 credit/min self-hosted."
          }
        }
      ]
    })} />

    <!-- Fonts: Roboto + Roboto Mono (bitHuman brand) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&family=Roboto+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <!-- No-FOUC theme init: set [data-theme] before paint -->
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem("bh-theme");
          if (!t)
            t = window.matchMedia("(prefers-color-scheme: dark)").matches
              ? "dark"
              : "light";
          document.documentElement.setAttribute("data-theme", t);
        } catch (e) {}
        document.documentElement.classList.add("js");
      })();
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <Nav />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <Search />

    <!-- theme toggle + scroll reveal -->
    <script is:inline>
      // Theme toggle
      window.__bhToggleTheme = function () {
        var el = document.documentElement;
        var next = el.getAttribute("data-theme") === "dark" ? "light" : "dark";
        el.setAttribute("data-theme", next);
        try {
          localStorage.setItem("bh-theme", next);
        } catch (e) {}
      };
      // Scroll reveal
      (function () {
        var all = document.querySelectorAll("[data-reveal]");
        // Fallback: if IntersectionObserver is unavailable, reveal everything
        // immediately so content is never stuck hidden (opacity:0).
        if (!("IntersectionObserver" in window)) {
          all.forEach(function (el) { el.classList.add("in"); });
          return;
        }
        var io = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (e) {
              if (e.isIntersecting) {
                e.target.classList.add("in");
                io.unobserve(e.target);
              }
            });
          },
          { threshold: 0.12 }
        );
        all.forEach(function (el) {
          io.observe(el);
        });
        // Backstop: never leave content hidden if observation stalls.
        setTimeout(function () {
          all.forEach(function (el) { el.classList.add("in"); });
        }, 2500);
      })();
      // Mobile nav
      window.__bhToggleMenu = function () {
        document.documentElement.classList.toggle("nav-open");
      };
      // Copy button on every prose code block
      (function () {
        document.querySelectorAll(".prose pre").forEach(function (pre) {
          var code = pre.querySelector("code");
          var text = (code ? code.innerText : pre.innerText);
          var btn = document.createElement("button");
          btn.className = "code-copy";
          btn.type = "button";
          btn.textContent = "Copy";
          btn.addEventListener("click", function () {
            navigator.clipboard.writeText(text).then(function () {
              btn.textContent = "Copied";
              setTimeout(function () { btn.textContent = "Copy"; }, 1400);
            }).catch(function () {});
          });
          pre.appendChild(btn);
        });
      })();
    </script>

    <style>
      .skip-link {
        position: absolute;
        left: -9999px;
        top: 0;
        z-index: 200;
        background: var(--color-primary);
        color: var(--color-on-primary);
        padding: 0.6rem 1rem;
        border-radius: var(--r-md);
      }
      .skip-link:focus { left: 12px; top: 12px; }
    </style>
  </body>
</html>
